# Базовый URL твоего backend'а на Railway (Settings → Domains, после деплоя)
VITE_API_BASE=https://CHANGE-ME.up.railway.app

# Твой production-домен на Vercel — должен совпадать с "url" в tonconnect-manifest.json
VITE_MANIFEST_URL=https://CHANGE-ME.vercel.app/tonconnect-manifest.json

# Адрес задеплоенного Collection-контракта (тот же, что в backend/.env)
VITE_COLLECTION_ADDRESS=EQAILrLs1EggzvLhSh8rpHtCIWbvVGeH8Je_pUZb2kYt4rFb

# Цена минта (просто для отображения — реальную проверяет backend)
VITE_MINT_PRICE_TON=5
